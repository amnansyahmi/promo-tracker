{
  "entities": {
    "Profile": {
      "title": "User Profile",
      "description": "Information about the registered users including their role.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["guest", "user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "displayName", "role", "createdAt"]
    },
    "Promo": {
      "title": "Promotion",
      "description": "Details of a giveaway, contest, or brand promotion.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "brandName": { "type": "string" },
        "promoType": { "type": "string" },
        "category": { "type": "string" },
        "country": { "type": "string" },
        "sourcePlatform": { "type": "string" },
        "sourceUrl": { "type": "string" },
        "sourceName": { "type": "string" },
        "imageUrl": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "expiryStatus": { "type": "string", "enum": ["Active", "Ending Soon", "Expired", "Unknown"] },
        "rewardTitle": { "type": "string" },
        "rewardValue": { "type": "string" },
        "rewardDescription": { "type": "string" },
        "requiredSpendAmount": { "type": "string" },
        "requiredPurchase": { "type": "boolean" },
        "entryMethod": { "type": "string" },
        "howToJoinSteps": { "type": "array", "items": { "type": "string" } },
        "eligibility": { "type": "array", "items": { "type": "string" } },
        "termsAndConditionsSummary": { "type": "array", "items": { "type": "string" } },
        "fullTermsUrl": { "type": "string" },
        "importantExclusions": { "type": "array", "items": { "type": "string" } },
        "winnerSelectionMethod": { "type": "string" },
        "winnerAnnouncementDate": { "type": "string" },
        "claimMethod": { "type": "string" },
        "difficultyLevel": { "type": "string" },
        "costLevel": { "type": "string" },
        "chanceLevel": { "type": "string" },
        "trustLevel": { "type": "string" },
        "tipsToWin": { "type": "array", "items": { "type": "string" } },
        "aiSummary": { "type": "string" },
        "aiConfidenceScore": { "type": "number" },
        "duplicateGroupId": { "type": "string" },
        "status": { "type": "string", "enum": ["Draft", "Pending Review", "Approved", "Rejected", "Expired"] },
        "createdByUserId": { "type": "string" },
        "reviewedByAdminId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "lastCheckedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "brandName", "status", "createdAt"]
    },
    "PromoSource": {
      "title": "Promotion Source",
      "description": "Information about sources for automated promo discovery.",
      "type": "object",
      "properties": {
        "sourceName": { "type": "string" },
        "sourceType": { "type": "string" },
        "baseUrl": { "type": "string" },
        "platform": { "type": "string" },
        "enabled": { "type": "boolean" },
        "crawlFrequency": { "type": "string" },
        "lastCrawledAt": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["sourceName", "baseUrl", "enabled", "createdAt"]
    },
    "PromoSubmission": {
      "title": "User Promo Submission",
      "description": "Promotions submitted by users for admin review.",
      "type": "object",
      "properties": {
        "submittedBy": { "type": "string" },
        "sourceUrl": { "type": "string" },
        "uploadedImageUrl": { "type": "string" },
        "rawText": { "type": "string" },
        "aiExtractedJson": { "type": "object" },
        "status": { "type": "string", "enum": ["Pending", "Approved", "Rejected"] },
        "adminNotes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["submittedBy", "status", "createdAt"]
    },
    "SavedPromo": {
      "title": "Saved Promotion",
      "description": "Promos saved by users.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "promoId": { "type": "string" },
        "reminderEnabled": { "type": "boolean" },
        "reminderDaysBeforeExpiry": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "promoId", "createdAt"]
    },
    "PromoEntry": {
      "title": "Promotion Entry",
      "description": "Participation tracking for a specific promotion.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "promoId": { "type": "string" },
        "enteredAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Entered", "Completed", "Pending Winner"] },
        "proofUrl": { "type": "string" }
      },
      "required": ["userId", "promoId", "enteredAt", "status"]
    },
    "AppNotification": {
      "title": "App Notification",
      "description": "In-app notifications for users.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "success", "warning", "error"] },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "link": { "type": "string" }
      },
      "required": ["userId", "title", "message", "type", "isRead", "createdAt"]
    }
  },
  "firestore": {
    "profiles/{userId}": {
      "schema": "Profile",
      "description": "User profiles stored by their Auth UID."
    },
    "promos/{promoId}": {
      "schema": "Promo",
      "description": "Main collection for promotions."
    },
    "promo_sources/{sourceId}": {
      "schema": "PromoSource",
      "description": "Sources for automated discovery."
    },
    "promo_submissions/{submissionId}": {
      "schema": "PromoSubmission",
      "description": "Submissions from users."
    },
    "saved_promos/{saveId}": {
      "schema": "SavedPromo",
      "description": "User's saved promotions."
    },
    "promo_entries/{entryId}": {
      "schema": "PromoEntry",
      "description": "User's participation records."
    },
    "notifications/{notificationId}": {
      "schema": "AppNotification",
      "description": "User specific notifications."
    }
  }
}
