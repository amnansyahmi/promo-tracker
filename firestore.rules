rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'amnansyahmi@gmail.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Profiles
    match /profiles/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && 
        incoming().keys().hasAll(['email', 'displayName', 'role', 'createdAt']) &&
        (incoming().role == 'user' || (incoming().role == 'admin' && request.auth.token.email == 'amnansyahmi@gmail.com'));
      allow update: if isOwner(userId) && 
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName']) || isAdmin();
    }

    // Promos
    match /promos/{promoId} {
      allow get: if true;
      allow list: if true; 
      allow create: if isSignedIn();
      allow write: if isAdmin();
    }

    // Promo Sources
    match /promo_sources/{sourceId} {
      allow read, write: if isAdmin();
    }

    // Promo Submissions
    match /promo_submissions/{submissionId} {
      allow get: if isSignedIn() && (resource.data.submittedBy == request.auth.uid || isAdmin());
      allow list: if isAdmin() || (isSignedIn() && resource.data.submittedBy == request.auth.uid);
      allow create: if isSignedIn() && incoming().submittedBy == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Saved Promos
    match /saved_promos/{saveId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && (incoming().userId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid && incoming().userId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Promo Entries
    match /promo_entries/{entryId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && (incoming().userId == request.auth.uid || isAdmin());
      allow update: if isAdmin(); // Only admins can update status from 'Entered' to 'Completed' etc.
      allow delete: if isAdmin();
    }

    // User Preferences
    match /user_preferences/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Notifications
    match /notifications/{notificationId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isAdmin(); // Only system/admins create notifications
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['isRead']) || isAdmin());
      allow delete: if isAdmin();
    }

    // Admin collection (to store uids of admins)
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via console or specialized script
    }
  }
}
